{
  "name": "misconception-map",
  "version": "0.1.0",
  "private": true,
  "description": "A teacher-facing diagnostic workspace for finding and testing mathematical misconceptions.",
  "scripts": {
    "dev": "npm run db:migrate && next dev --hostname 127.0.0.1",
    "build": "next build",
    "start": "node scripts/start.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm run verify:privacy && npm run verify:phase1 && npm run verify:hierarchy && npm run verify:phase2 && npm run verify:images && npm run verify:pdf && npm run verify:phase4 && npm run verify:diagnosis-contracts && npm run verify:accountability && npm run verify:universal-correction && npm run verify:full-page-timeout && npm run verify:navigation && npm run verify:representation && npm run verify:error-inventory && npm run verify:readiness && npm run build",
    "db:migrate": "node scripts/migrate.mjs",
    "seed": "npm run db:migrate && node scripts/seed.mjs",
    "sample-work": "node scripts/generate-sample-work.mjs",
    "db:check": "node scripts/check-db.mjs",
    "verify:phase1": "node scripts/verify-phase-one.mjs",
    "verify:hierarchy": "node --no-warnings --experimental-strip-types scripts/verify-hierarchical-workflow.mjs",
    "verify:phase2": "node scripts/verify-phase-two-output.mjs",
    "verify:images": "node scripts/verify-image-regressions.mjs",
    "verify:pdf": "node scripts/verify-pdf-intake.mjs",
    "verify:phase4": "node scripts/verify-phase-four.mjs",
    "verify:diagnosis-contracts": "node scripts/verify-diagnosis-persistence-contracts.mjs",
    "verify:accountability": "node scripts/verify-accountable-corrections.mjs",
    "verify:universal-correction": "node scripts/verify-universal-correction.mjs",
    "verify:full-page-timeout": "node scripts/verify-full-page-timeout.mjs",
    "verify:navigation": "node scripts/verify-navigation.mjs",
    "verify:representation": "node scripts/verify-representation-clarity.mjs",
    "verify:error-inventory": "node scripts/verify-error-inventory.mjs",
    "verify:readiness": "node scripts/verify-submission-readiness.mjs",
    "verify:privacy": "node scripts/verify-privacy.mjs"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "packageManager": "npm@11.13.0",
  "overrides": {
    "next": {
      "postcss": "8.5.19"
    }
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "next": "^16.2.10",
    "openai": "^6.46.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.35.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "tailwindcss": "^4.3.2",
    "typescript": ">=6.0.0 <6.1.0"
  }
}
