# Required for live diagnosis. Class and assignment setup work without it.
OPENAI_API_KEY=

# Hosted deployment only. Local mode ignores these values.
HOSTED_MODE=0
JUDGE_ACCESS_CODE=
DATA_DIR=
OPENAI_DAILY_BUDGET_USD=5
OPENAI_REQUESTS_PER_SESSION_HOUR=20

# GPT-5.6 Sol list pricing as of July 2026; override if pricing changes.
OPENAI_INPUT_USD_PER_MILLION=5
OPENAI_OUTPUT_USD_PER_MILLION=30

# Optional shell-level override for an isolated SQLite database.
# Export or prefix npm commands with this value; migration scripts do not read
# MISCONCEPTION_MAP_DB_PATH from .env.local.
# MISCONCEPTION_MAP_DB_PATH=data/misconception-map.db
